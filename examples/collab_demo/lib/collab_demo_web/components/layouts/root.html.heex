<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>ProsemirrorEx Collab Demo</title>
  <link rel="stylesheet" href={~p"/assets/css/app.css"}/>
  <script defer src={~p"/assets/js/app.js"}></script>
  <style>
    body { background: #f5f5f5; margin: 0; }
    .ProseMirror { outline: none; min-height: 260px; }
    .ProseMirror p { margin-bottom: 0.5em; line-height: 1.6; }
    .ProseMirror h1, .ProseMirror h2, .ProseMirror h3 { margin: 0.5em 0 0.3em; line-height: 1.3; }
    .ProseMirror h1 { font-size: 1.6em; }
    .ProseMirror h2 { font-size: 1.3em; }
    .ProseMirror blockquote { border-left: 3px solid #ddd; padding-left: 12px; color: #666; }
    .ProseMirror ul, .ProseMirror ol { padding-left: 24px; }
    .ProseMirror code { background: #f0f0f0; padding: 2px 4px; border-radius: 3px; }
    .ProseMirror pre { background: #282c34; color: #abb2bf; padding: 12px; border-radius: 6px; }
    .ProseMirror pre code { background: none; padding: 0; }
    .ProseMirror hr { border: none; border-top: 2px solid #eee; margin: 1em 0; }
  </style>
</head>
<body>
  <%= @inner_content %>
</body>
</html>
